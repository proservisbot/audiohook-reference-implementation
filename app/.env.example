# AudioHook Server Configuration
SERVERPORT=3000
SERVERHOST=127.0.0.1

# =============================================================================
# TRANSCRIPTION SERVICE CONFIGURATION
# =============================================================================
# Options: deepgram | tccp | both
# - deepgram: Only Deepgram transcription (default)
# - tccp: Only TCCP (AudioCodes) event forwarding
# - both: Deepgram transcription + TCCP event forwarding
TRANSCRIPTION_SERVICE=deepgram

# =============================================================================
# DEEPGRAM CONFIGURATION (required for deepgram or both modes)
# =============================================================================
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-2

# =============================================================================
# AUDIOCODES BOT API CONFIGURATION (required for tccp or both modes)
# =============================================================================
# These settings connect to the AudioCodes Bot API for TCCP integration
AUDIOCODES_BOT_URL=https://your-audiocodes-server/audiocodes/your-callcenter/bot
AUDIOCODES_API_KEY=your_audiocodes_api_key_here
EVENT_WEBHOOK_URL=https://your-audiocodes-server/callstatus/your-callcenter/event

# Legacy TCCP env vars (fallback if AudioCodes vars not set)
# You can use these instead of AUDIOCODES_BOT_URL/AUDIOCODES_API_KEY
# TCCP_ENDPOINT=wss://your-tccp-service/ws
# TCCP_API_KEY=your_tccp_api_key

# =============================================================================
# AUDIO SETTINGS
# =============================================================================
AUDIO_SAMPLE_RATE=8000
AUDIO_CHANNELS=1

# =============================================================================
# SERVER & LOGGING
# =============================================================================
NODE_ENV=development
# Set to 'production' for production deployments

# =============================================================================
# AUTHENTICATION (optional, for production)
# =============================================================================
# Authentication strategy: session, request, or jwt
# - session: HTTP signature verification during session (default)
# - request: HTTP signature verification during WebSocket upgrade
# - jwt: JWT token verification (for Genesys AudioHook)
SESSION_AUTH_STRATEGY=session

# HTTP signature authentication (for session/request strategies)
# AUDIOHOOK_SIGNATURE_SECRET=your_signature_secret
# For production, configure HTTP signature authentication

# JWT authentication (for jwt strategy)
# Enable JWT authentication
AUDIOHOOK_JWT_AUTH_ENABLED=true

# JWT client secrets - choose one of the following formats:
# Option 1: Single secret for all organizations
AUDIOHOOK_JWT_CLIENT_SECRET=your_genesys_client_secret_here

# Option 2: Multi-tenant support (one secret per org)
# AUDIOHOOK_JWT_SECRET_org1=secret_for_org1
# AUDIOHOOK_JWT_SECRET_org2=secret_for_org2

# Option 3: JSON format for multiple orgs
# AUDIOHOOK_JWT_SECRETS={"org1": "secret1", "org2": "secret2"}

# JWT validation settings
AUDIOHOOK_JWT_ISSUER=genesys
AUDIOHOOK_JWT_AUDIENCE=audiohook
AUDIOHOOK_JWT_CLOCK_SKEW=60

# =============================================================================
# EXAMPLE CONFIGURATIONS
# =============================================================================

# Example 1: Deepgram only (default)
# TRANSCRIPTION_SERVICE=deepgram
# DEEPGRAM_API_KEY=your_key_here

# Example 2: TCCP only (forwards transcripts and events to AudioCodes)
# TRANSCRIPTION_SERVICE=tccp
# AUDIOCODES_BOT_URL=https://.../bot
# AUDIOCODES_API_KEY=your_key
# EVENT_WEBHOOK_URL=https://.../event

# Example 3: Both (Deepgram transcribes, TCCP receives events)
# TRANSCRIPTION_SERVICE=both
# DEEPGRAM_API_KEY=your_key_here
# AUDIOCODES_BOT_URL=https://.../bot
# AUDIOCODES_API_KEY=your_key
# EVENT_WEBHOOK_URL=https://.../event
